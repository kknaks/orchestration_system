{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/orchestrate.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ORCHESTRATE_DRY_RUN=1 ORCHESTRATION_RUNTIME=claude bash -c ' *)"
    ]
  }
}
